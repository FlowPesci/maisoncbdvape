# .env.example — modèle pour les variables d'environnement.
# Copier en .env (gitignored) pour le dev local avec wrangler.
# En PROD (Cloudflare Pages), configurer dans Settings → Environment variables.

# ─── Viva Wallet ────────────────────────────────────────────────────────────
VIVA_MERCHANT_ID=
VIVA_API_KEY=
VIVA_SOURCE_CODE=
VIVA_ENV=demo
VIVA_WEBHOOK_KEY=

# ─── Resend (emails) ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Tabac Gex <onboarding@resend.dev>
EMAIL_MERCHANT=

# ─── Site ───────────────────────────────────────────────────────────────────
SITE_URL=https://tabacgex.pages.dev

# ─── GitHub OAuth (pour Decap CMS + back-office admin) ──────────────────────
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_REPO=FlowPesci/tabacgex
