{# ──────────────────────────────────────────────────────────────────────────
   base.njk — Layout principal MaisonCBDVape
────────────────────────────────────────────────────────────────────────── #}
<!DOCTYPE html>
<html lang="{{ site.lang }}" class="scroll-smooth">
<head>
  {% include "partials/head.njk" %}
</head>

<body class="antialiased" style="background:var(--dark); color:var(--text);">

  {# ─── Curseur personnalisé (desktop uniquement via CSS media query) ── #}
  <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>
  <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>

  {# ─── Popup vérification d'âge ───────────────────────────────────── #}
  <div id="age-gate" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(10,8,6,0.98);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);" role="dialog" aria-modal="true" aria-labelledby="age-gate-title">
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1.5rem;">
      <div style="max-width:420px;width:100%;text-align:center;">

        {# Logo #}
        <div style="margin-bottom:2rem;">
          <a href="/" style="text-decoration:none;display:inline-block;">
            <span style="font-family:'Cormorant Garamond',Georgia,serif;font-size:2.2rem;font-weight:300;letter-spacing:0.18em;text-transform:uppercase;line-height:1;">
              <span style="color:#F5F0E8;">MAISON</span><span style="color:#C9A96E;">CBD</span><span style="color:#F5F0E8;">VAPE</span>
            </span>
          </a>
        </div>

        {# Icône #}
        <div style="width:60px;height:60px;border-radius:50%;border:1px solid rgba(201,169,110,0.4);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
          <svg style="width:26px;height:26px;color:#C9A96E;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>

        <p style="font-size:10px;text-transform:uppercase;letter-spacing:4px;color:#8A8070;margin-bottom:0.75rem;">Vérification d'âge</p>
        <h2 id="age-gate-title" style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;color:#F5F0E8;letter-spacing:2px;text-transform:uppercase;margin-bottom:1rem;line-height:1.1;">Avez-vous 18 ans<br/>ou plus ?</h2>
        <p style="font-size:12.5px;color:#8A8070;margin-bottom:2rem;line-height:1.7;">La vente de tabac, CBD et produits de vape est <strong style="color:#D8D0C4;">strictement réservée aux majeurs</strong>. En entrant sur ce site, vous certifiez avoir 18 ans ou plus.</p>

        <div style="display:flex;flex-direction:column;gap:0.75rem;">
          <button id="age-gate-yes" style="width:100%;padding:1rem;background:#C9A96E;color:#0E0C09;font-size:10.5px;text-transform:uppercase;letter-spacing:2.5px;border:none;cursor:none;font-family:'DM Sans',sans-serif;font-weight:500;transition:opacity .2s;" onmouseover="this.style.opacity='.82'" onmouseout="this.style.opacity='1'">
            Oui, j'ai 18 ans ou plus
          </button>
          <button id="age-gate-no" style="width:100%;padding:1rem;background:transparent;color:#8A8070;font-size:10.5px;text-transform:uppercase;letter-spacing:2px;border:1px solid rgba(201,169,110,0.2);cursor:none;font-family:'DM Sans',sans-serif;transition:border-color .2s;" onmouseover="this.style.borderColor='rgba(201,169,110,0.5)'" onmouseout="this.style.borderColor='rgba(201,169,110,0.2)'">
            Non, j'ai moins de 18 ans
          </button>
        </div>

        <p style="font-size:10.5px;color:#4A4040;margin-top:1.5rem;letter-spacing:.03em;">En cliquant « Oui », vous confirmez être majeur conformément à la législation en vigueur.</p>
      </div>
    </div>
  </div>

  {# ─── Script age-gate + curseur ──────────────────────────────────── #}
  <script>
  (function () {
    // Age gate
    var KEY = 'mcv_age_ok';
    var overlay = document.getElementById('age-gate');
    if (overlay) {
      if (sessionStorage.getItem(KEY)) {
        overlay.style.display = 'none';
      } else {
        overlay.style.display = 'block';
        document.body.style.overflow = 'hidden';
      }
      document.getElementById('age-gate-yes').addEventListener('click', function () {
        sessionStorage.setItem(KEY, '1');
        overlay.style.opacity = '0';
        overlay.style.transition = 'opacity 0.4s';
        setTimeout(function () { overlay.style.display = 'none'; document.body.style.overflow = ''; }, 400);
      });
      document.getElementById('age-gate-no').addEventListener('click', function () {
        window.location.href = 'https://www.google.fr';
      });
    }

    // ── Curseur magnétique (pointer-capable devices only) ──────────────
    var dot  = document.getElementById('cursor-dot');
    var ring = document.getElementById('cursor-ring');
    if (!dot || !ring) return;

    var mx = -200, my = -200;
    var rx = -200, ry = -200;
    var ringTargetX = null, ringTargetY = null;
    var currentMagnet = null;
    var PULL  = 0.30;   // force de déplacement de l'élément (0→1)
    var LERP  = 0.14;   // vitesse de suivi de l'anneau

    // Sélecteurs éligibles au magnétisme
    var MAGNET_SEL = 'a, button, [role="button"], .btn-gold, .btn-ghost, .icon-btn, .nav-link';

    document.addEventListener('mousemove', function(e) {
      mx = e.clientX;
      my = e.clientY;
      dot.style.left = mx + 'px';
      dot.style.top  = my + 'px';
      updateMagnets(mx, my);
    });

    function updateMagnets(cx, cy) {
      var magnets = document.querySelectorAll(MAGNET_SEL);
      var best = null, bestDist = Infinity;

      magnets.forEach(function(el) {
        var r = el.getBoundingClientRect();
        // ignorer les éléments hors viewport
        if (r.width === 0 || r.bottom < 0 || r.top > window.innerHeight) return;
        var ex = r.left + r.width  / 2;
        var ey = r.top  + r.height / 2;
        var dist = Math.sqrt((cx - ex) * (cx - ex) + (cy - ey) * (cy - ey));
        // seuil = demi-diagonale + marge de 18px
        var thresh = Math.sqrt(r.width * r.width + r.height * r.height) * 0.6 + 18;
        if (dist < thresh && dist < bestDist) {
          bestDist = dist;
          best = { el: el, ex: ex, ey: ey, dist: dist, thresh: thresh };
        }
      });

      // Libérer l'ancien aimant si on change d'élément
      if (currentMagnet && (!best || currentMagnet.el !== best.el)) {
        currentMagnet.el.style.transform = '';
        currentMagnet.el.style.transition = 'transform .45s cubic-bezier(.25,.46,.45,.94), opacity .3s, color .3s';
        currentMagnet = null;
        ringTargetX   = null;
        ringTargetY   = null;
        dot.classList.remove('hovering');
        ring.classList.remove('hovering');
      }

      if (best) {
        var pull = 1 - (best.dist / best.thresh);
        var dx = (cx - best.ex) * pull * PULL;
        var dy = (cy - best.ey) * pull * PULL;

        best.el.style.transform  = 'translate(' + dx.toFixed(1) + 'px,' + dy.toFixed(1) + 'px)';
        best.el.style.transition = 'transform .1s ease';

        // L'anneau se centre sur l'élément (légèrement décalé vers le curseur)
        ringTargetX = best.ex + dx * 0.5;
        ringTargetY = best.ey + dy * 0.5;

        if (!currentMagnet || currentMagnet.el !== best.el) {
          dot.classList.add('hovering');
          ring.classList.add('hovering');
        }
        currentMagnet = best;
      }
    }

    // Anneau — suivi lerp vers la cible magnétique ou le curseur
    (function animRing() {
      var destX = ringTargetX !== null ? ringTargetX : mx;
      var destY = ringTargetY !== null ? ringTargetY : my;
      rx += (destX - rx) * LERP;
      ry += (destY - ry) * LERP;
      ring.style.left = rx + 'px';
      ring.style.top  = ry + 'px';
      requestAnimationFrame(animRing);
    })();
  })();
  </script>

  {% include "partials/header.njk" %}

  {# Spacer header fixe #}
  <div style="height:72px;" aria-hidden="true"></div>

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  {# ─── Script global ───────────────────────────────────────────────── #}
  <script src="/assets/js/tabacgex.js?v={{ '/assets/js/tabacgex.js' | contentHash }}" defer></script>
</body>
</html>
