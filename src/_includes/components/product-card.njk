{# ──────────────────────────────────────────────────────────────────────────
   product-card.njk — composant atomique réutilisable
   Usage : {% from "components/product-card.njk" import productCard %}
           {{ productCard(produit) }}
   Layout flex column → bouton "Ajouter" toujours aligné en bas, même si
   les titres ou prix prennent plus ou moins de lignes.
────────────────────────────────────────────────────────────────────────── #}

{% macro productCard(produit, classes = "") %}
  {# ─ Détermination du badge prioritaire ─ #}
  {% set badgeTag = null %}
  {% set badgeClass = "" %}
  {% if "nouveaute" in (produit.tags or []) %}
    {% set badgeTag = "Nouveau" %}{% set badgeClass = "badge-nouveau" %}
  {% elif "hot" in (produit.tags or []) %}
    {% set badgeTag = "Hot" %}{% set badgeClass = "badge-hot" %}
  {% elif "promo" in (produit.tags or []) or produit.prixBarre %}
    {% set badgeTag = "Promo" %}{% set badgeClass = "badge-promo" %}
  {% elif produit.categorie == "cbd" %}
    {% set badgeTag = "CBD" %}{% set badgeClass = "badge-cbd" %}
  {% endif %}

  {# ─ Détermination du badge stock ─ #}
  {% set stockLabel = "En stock" %}
  {% set stockClass = "stock-badge" %}
  {% set isOutOfStock = false %}
  {% if produit.stock <= 0 or produit.statutStock == "rupture" %}
    {% set stockLabel = "Rupture" %}{% set stockClass = "badge-rupture" %}
    {% set isOutOfStock = true %}
  {% elif produit.stock <= 5 %}
    {% set stockLabel = "Stock faible" %}{% set stockClass = "stock-low" %}
  {% endif %}

  <article class="product-card flex flex-col {{ classes }}"
           data-product-id="{{ produit.id }}"
           data-marque="{{ produit.marque }}"
           data-prix="{{ produit.prix }}"
           data-categorie="{{ produit.categorie }}"
           data-tags="{{ (produit.tags or []) | join(',') }}">

    {# ─── Image + badges ──────────────────────────────────────── #}
    <a href="/produits/{{ produit.id }}/" class="block relative overflow-hidden shrink-0" style="aspect-ratio:1/1;background:#fff;">
      <img src="{{ produit.image }}"
           alt="{{ produit.nom }}"
           loading="lazy"
           class="w-full h-full object-contain transition-transform duration-500 hover:scale-105"/>

      <div class="absolute top-3 left-3">
        <span class="{{ stockClass }} text-xs font-mono font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
          {{ stockLabel }}
        </span>
      </div>

      {% if badgeTag %}
        <div class="absolute top-3 right-3">
          <span class="{{ badgeClass }} text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
            {{ badgeTag }}
          </span>
        </div>
      {% endif %}
    </a>

    {# ─── Contenu (flex column → push CTA en bas) ────────────── #}
    <div class="p-5 flex flex-col flex-1">
      <div style="color:var(--muted);font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;margin-bottom:.25rem;font-family:'DM Sans',sans-serif;">
        {{ produit.categorie | capitalize }} · {{ produit.marque }}
      </div>

      <h3 style="color:var(--cream);font-weight:500;font-size:.875rem;line-height:1.35;margin-bottom:.75rem;">
        <a href="/produits/{{ produit.id }}/" style="color:inherit;text-decoration:none;transition:color .2s;"
           onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--cream)'">
          {{ produit.nom }}
        </a>
      </h3>

      {# Spacer flex pour pousser prix + bouton en bas #}
      <div class="flex-1"></div>

      <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
        <div class="flex items-center gap-2">
          {% if produit.prixBarre %}
            <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:var(--gold);">
              {{ produit.prix | eur }}{% if produit.unitePrix %}/{{ produit.unitePrix }}{% endif %}
            </div>
            <div style="font-family:'DM Sans',sans-serif;color:var(--muted);font-size:.875rem;text-decoration:line-through;">
              {{ produit.prixBarre | eur }}
            </div>
          {% else %}
            <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:var(--gold);">
              {{ produit.prix | eur }}{% if produit.unitePrix %}/{{ produit.unitePrix }}{% endif %}
            </div>
          {% endif %}
        </div>

        {% if produit.note %}
          <div class="flex items-center gap-1 text-yellow-400 text-xs">
            {% set fullStars = produit.note | int %}
            {% for i in range(0, 5) %}{% if i < fullStars %}★{% else %}☆{% endif %}{% endfor %}
            {% if produit.nombreAvis %}<span class="text-smoke">({{ produit.nombreAvis }})</span>{% endif %}
          </div>
        {% endif %}
      </div>

      {# ─── CTA toujours en bas ────────────────────────────────── #}
      <button class="add-cart-btn w-full py-2.5 flex items-center justify-center gap-2 mt-auto"
              data-add-to-cart="{{ produit.id }}"
              {% if isOutOfStock %}disabled{% endif %}
              aria-label="{% if isOutOfStock %}Produit en rupture{% else %}Ajouter {{ produit.nom }} au panier{% endif %}">
        {% if isOutOfStock %}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 14L21 3m0 0v6m0-6h-6"/>
          </svg>
          Me prévenir
        {% else %}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          Ajouter au panier
        {% endif %}
      </button>
    </div>
  </article>
{% endmacro %}
