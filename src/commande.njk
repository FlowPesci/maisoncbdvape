          </select>
          <span class="error-msg hidden mt-1 text-xs text-red-400" data-error-for="creneauHeure"></span>
        </label>
      </div>

      {# ── Script calendrier ── #}
      <script>
      (function () {
        const hiddenDate  = document.getElementById('creneauDate-hidden');
        const calGrid     = document.getElementById('cal-grid');
        const calTitle    = document.getElementById('cal-title');
        const calPrev     = document.getElementById('cal-prev');
        const calNext     = document.getElementById('cal-next');
        const calLabel    = document.getElementById('cal-selected-label');
        const calText     = document.getElementById('cal-selected-text');
        const heureSelect = document.getElementById('creneauHeure-select');
        // Lun / Mar / Jeu / Ven : 7h30–12h30 et 14h–19h
        const SLOTS_LMJV = [
          { value: '07:30', label: '7 h 30 – 9 h' },
          { value: '09:00', label: '9 h – 10 h 30' },
          { value: '10:30', label: '10 h 30 – 12 h' },
          { value: '14:00', label: '14 h – 15 h 30' },
          { value: '15:30', label: '15 h 30 – 17 h' },
          { value: '17:00', label: '17 h – 18 h 30' },
        ];
        // Mercredi : 7h30–12h00 et 14h–19h
        const SLOTS_MER = [
          { value: '07:30', label: '7 h 30 – 9 h' },
          { value: '09:00', label: '9 h – 10 h 30' },
          { value: '10:30', label: '10 h 30 – 12 h' },
          { value: '14:00', label: '14 h – 15 h 30' },
          { value: '15:30', label: '15 h 30 – 17 h' },
          { value: '17:00', label: '17 h – 18 h 30' },
        ];
        // Samedi : 8h–12h30 et 14h–18h40
        const SLOTS_SAM = [
          { value: '08:00', label: '8 h – 9 h 30' },
          { value: '09:30', label: '9 h 30 – 11 h' },
          { value: '11:00', label: '11 h – 12 h 30' },
          { value: '14:00', label: '14 h – 15 h 30' },
          { value: '15:30', label: '15 h 30 – 17 h' },
          { value: '17:00', label: '17 h – 18 h 30' },
        ];
        // Dimanche : 8h–12h
        const SLOTS_DIM = [
          { value: '08:00', label: '8 h – 9 h 30' },
          { value: '09:30', label: '9 h 30 – 11 h' },
          { value: '11:00', label: '11 h – 12 h' },
        ];
        const today = new Date(); today.setHours(0,0,0,0);
        const minDate = new Date(today); minDate.setDate(minDate.getDate() + 1);
        let viewYear = minDate.getFullYear(), viewMonth = minDate.getMonth(), selectedDate = null;
        function isoStr(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
        function frStr(d) { return d.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' }); }
        function renderHeure(dow, forDate) {
          // dow : 0=dim, 1=lun, 2=mar, 3=mer, 4=jeu, 5=ven, 6=sam
          const map = { 0: SLOTS_DIM, 1: SLOTS_LMJV, 2: SLOTS_LMJV, 3: SLOTS_MER, 4: SLOTS_LMJV, 5: SLOTS_LMJV, 6: SLOTS_SAM };
          let slots = map[dow] || SLOTS_LMJV;

          // Filtrer les créneaux trop proches si la date sélectionnée est demain
          const now = new Date();
          const tomorrow = new Date(now); tomorrow.setDate(tomorrow.getDate() + 1); tomorrow.setHours(0,0,0,0);
          const isNextDay = forDate && forDate.toDateString() === tomorrow.toDateString();
          if (isNextDay) {
            // Blocage si le créneau commence dans moins de 4 heures (en heure locale)
            const minHour = now.getHours() + 4 + now.getMinutes() / 60;
            slots = slots.filter(s => {
              const [h, m] = s.value.split(':').map(Number);
              return (h + m / 60) > minHour;
            });
          }

          heureSelect.innerHTML = '<option value="">— Choisir —</option>' + slots.map(s => `<option value="${s.value}">${s.label}</option>`).join('');
          heureSelect.disabled = slots.length === 0;
          if (slots.length === 0) heureSelect.innerHTML = '<option value="">Aucun créneau disponible</option>';
        }
        function renderCalendar() {
          calTitle.textContent = new Date(viewYear, viewMonth, 1).toLocaleDateString('fr-FR', { month:'long', year:'numeric' });
          const startDow = (new Date(viewYear, viewMonth, 1).getDay() + 6) % 7;
          const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
          let html = '';
          for (let i = 0; i < startDow; i++) html += '<span></span>';
          for (let d = 1; d <= daysInMonth; d++) {
            const date = new Date(viewYear, viewMonth, d);
            const iso = isoStr(date);
            const isDisabled = date < minDate;
            const isSelected = selectedDate && isoStr(selectedDate) === iso;
            const isToday = isoStr(date) === isoStr(today);
            let cls = 'w-full aspect-square rounded-lg text-sm font-mono flex items-center justify-center transition-all ';
            if (isDisabled) cls += 'text-dark-border cursor-not-allowed';
            else if (isSelected) cls += 'bg-neon-green text-dark-bg font-bold cursor-pointer';
            else if (isToday) cls += 'border border-neon-green/40 text-white cursor-pointer hover:bg-dark-border';
            else cls += 'text-smoke hover:bg-dark-border hover:text-white cursor-pointer';
            html += `<button type="button" class="${cls}" data-date="${iso}" ${isDisabled ? 'disabled' : ''}>${d}</button>`;
          }
          calGrid.innerHTML = html;
          calPrev.disabled = (viewYear === minDate.getFullYear() && viewMonth === minDate.getMonth());
          calPrev.classList.toggle('opacity-30', calPrev.disabled);
        }
        calGrid.addEventListener('click', function(e) {
          const btn = e.target.closest('button[data-date]');
          if (!btn || btn.disabled) return;
          selectedDate = new Date(btn.dataset.date + 'T00:00:00');
          hiddenDate.value = btn.dataset.date;
          calText.textContent = frStr(selectedDate);
          calLabel.classList.remove('hidden');
          renderHeure(selectedDate.getDay(), selectedDate);
          renderCalendar();
        });
        calPrev.addEventListener('click', () => { viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; } renderCalendar(); });
        calNext.addEventListener('click', () => { viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; } renderCalendar(); });
        renderCalendar();
      })();
      </script>

      {# ─── Adresse de livraison (masqué par défaut) ─── #}
      <div id="section-livraison" class="hidden rounded-2xl bg-dark-card border border-dark-border p-6">
