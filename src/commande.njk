            <span style="text-align:center;font-size:.7rem;font-family:'Space Mono',monospace;color:var(--muted);padding:.25rem 0;">Ma</span>
            <span style="text-align:center;font-size:.7rem;font-family:'Space Mono',monospace;color:var(--muted);padding:.25rem 0;">Me</span>
            <span style="text-align:center;font-size:.7rem;font-family:'Space Mono',monospace;color:var(--muted);padding:.25rem 0;">Je</span>
            <span style="text-align:center;font-size:.7rem;font-family:'Space Mono',monospace;color:var(--muted);padding:.25rem 0;">Ve</span>
            <span style="text-align:center;font-size:.7rem;font-family:'Space Mono',monospace;color:var(--muted);padding:.25rem 0;">Sa</span>
            <span style="text-align:center;font-size:.7rem;font-family:'Space Mono',monospace;color:var(--muted);padding:.25rem 0;">Di</span>
