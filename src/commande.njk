            ✓ <span id="cal-selected-text" style="color:var(--gold);font-weight:600;"></span>
          </p>
        </div>

        <label class="block">
          <span style="display:block;font-size:.8rem;color:var(--cream);margin-bottom:.5rem;font-family:'DM Sans',sans-serif;">Heure approximative *</span>
          <select name="creneauHeure" id="creneauHeure-select"
                  style="width:100%;background:var(--dark);border:1px solid var(--borderl);border-radius:2px;padding:.75rem 1rem;color:var(--cream);font-size:.875rem;font-family:'DM Sans',sans-serif;outline:none;appearance:auto;transition:border-color .2s;"
                  onfocus="this.style.borderColor='rgba(201,169,110,0.5)'" onblur="this.style.borderColor='var(--borderl)'">
            <option value="" style="background:#161410;color:#D8D0C4;">— Choisir une date d'abord —</option>
          </select>
          <span class="error-msg hidden mt-1 text-xs text-red-400" data-error-for="creneauHeure"></span>
        </label>
      </div>

      {# ── Script calendrier ── #}
      <script>
      (function () {
        const hiddenDate  = document.getElementById('creneauDate-hidden');
        const calGrid     = document.getElementById('cal-grid');
        const calTitle    = document.getElementById('cal-title');
        const calPrev     = document.getElementById('cal-prev');
        const calNext     = document.getElementById('cal-next');
        const calLabel    = document.getElementById('cal-selected-label');
        const calText     = document.getElementById('cal-selected-text');
        const heureSelect = document.getElementById('creneauHeure-select');
        const SLOTS_LMJV = [
          { value: '07:30', label: '7 h 30 – 9 h' },
          { value: '09:00', label: '9 h – 10 h 30' },
          { value: '10:30', label: '10 h 30 – 12 h' },
          { value: '14:00', label: '14 h – 15 h 30' },
          { value: '15:30', label: '15 h 30 – 17 h' },
          { value: '17:00', label: '17 h – 18 h 30' },
        ];
        const SLOTS_MER = SLOTS_LMJV;
        const SLOTS_SAM = [
          { value: '08:00', label: '8 h – 9 h 30' },
          { value: '09:30', label: '9 h 30 – 11 h' },
          { value: '11:00', label: '11 h – 12 h 30' },
          { value: '14:00', label: '14 h – 15 h 30' },
          { value: '15:30', label: '15 h 30 – 17 h' },
          { value: '17:00', label: '17 h – 18 h 30' },
        ];
        const SLOTS_DIM = [
          { value: '08:00', label: '8 h – 9 h 30' },
          { value: '09:30', label: '9 h 30 – 11 h' },
          { value: '11:00', label: '11 h – 12 h' },
        ];
        const today = new Date(); today.setHours(0,0,0,0);
        const minDate = new Date(today); minDate.setDate(minDate.getDate() + 1);
        let viewYear = minDate.getFullYear(), viewMonth = minDate.getMonth(), selectedDate = null;
        function isoStr(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
        function frStr(d) { return d.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' }); }
        function renderHeure(dow, forDate) {
          const map = { 0: SLOTS_DIM, 1: SLOTS_LMJV, 2: SLOTS_LMJV, 3: SLOTS_MER, 4: SLOTS_LMJV, 5: SLOTS_LMJV, 6: SLOTS_SAM };
          let slots = map[dow] || SLOTS_LMJV;
          const now = new Date();
          const tomorrow = new Date(now); tomorrow.setDate(tomorrow.getDate() + 1); tomorrow.setHours(0,0,0,0);
          const isNextDay = forDate && forDate.toDateString() === tomorrow.toDateString();
          if (isNextDay) {
            const minHour = now.getHours() + 4 + now.getMinutes() / 60;
            slots = slots.filter(s => { const [h, m] = s.value.split(':').map(Number); return (h + m / 60) > minHour; });
          }
          const bg = '#161410', fg = '#D8D0C4';
          heureSelect.innerHTML = `<option value="" style="background:${bg};color:${fg};">— Choisir —</option>` +
            slots.map(s => `<option value="${s.value}" style="background:${bg};color:${fg};">${s.label}</option>`).join('');
          heureSelect.disabled = slots.length === 0;
          if (slots.length === 0) heureSelect.innerHTML = `<option value="" style="background:${bg};color:${fg};">Aucun créneau disponible</option>`;
        }
        function renderCalendar() {
          calTitle.textContent = new Date(viewYear, viewMonth, 1).toLocaleDateString('fr-FR', { month:'long', year:'numeric' });
          const startDow = (new Date(viewYear, viewMonth, 1).getDay() + 6) % 7;
          const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
          let html = '';
          for (let i = 0; i < startDow; i++) html += '<span></span>';
          for (let d = 1; d <= daysInMonth; d++) {
            const date = new Date(viewYear, viewMonth, d);
            const iso = isoStr(date);
            const isDisabled = date < minDate;
            const isSelected = selectedDate && isoStr(selectedDate) === iso;
            let style, cls = 'w-full aspect-square text-xs font-mono flex items-center justify-center transition-all ';
            if (isDisabled) {
              style = 'border-radius:4px;color:rgba(138,128,112,0.3);cursor:not-allowed;';
              cls += '';
            } else if (isSelected) {
              style = 'border-radius:4px;background:var(--gold);color:var(--dark);font-weight:700;cursor:pointer;';
            } else {
              style = 'border-radius:4px;color:var(--muted);cursor:pointer;';
              cls += 'hover:bg-zinc-800 hover:text-mcv-cream';
            }
            html += `<button type="button" class="${cls}" style="${style}" data-date="${iso}" ${isDisabled ? 'disabled' : ''}>${d}</button>`;
          }
          calGrid.innerHTML = html;
          calPrev.disabled = (viewYear === minDate.getFullYear() && viewMonth === minDate.getMonth());
          calPrev.style.opacity = calPrev.disabled ? '0.3' : '1';
        }
        calGrid.addEventListener('click', function(e) {
          const btn = e.target.closest('button[data-date]');
          if (!btn || btn.disabled) return;
          selectedDate = new Date(btn.dataset.date + 'T00:00:00');
          hiddenDate.value = btn.dataset.date;
          calText.textContent = frStr(selectedDate);
          calLabel.classList.remove('hidden');
          renderHeure(selectedDate.getDay(), selectedDate);
          renderCalendar();
        });
        calPrev.addEventListener('click', () => { viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; } renderCalendar(); });
        calNext.addEventListener('click', () => { viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; } renderCalendar(); });
        renderCalendar();
      })();
      </script>

      {# ─── Adresse de livraison (masqué par défaut) ─── #}
      <div id="section-livraison" class="hidden" style="border-radius:2px;background:var(--dark2);border:1px solid var(--borderl);padding:1.5rem;">
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.25rem;letter-spacing:.12em;color:var(--cream);margin-bottom:.5rem;font-weight:400;">ADRESSE DE LIVRAISON</h2>
        <p style="font-size:.75rem;color:var(--muted);margin-bottom:1.25rem;font-family:'DM Sans',sans-serif;line-height:1.6;">
          📦 Expédition Colissimo sous 2 à 4 jours ouvrés après confirmation.<br/>
          Livraison gratuite dès 30 € d'achat, sinon 3,90 €.
        </p>
        <div class="space-y-4">
          <label class="block">
            <span style="display:block;font-size:.8rem;color:var(--cream);margin-bottom:.5rem;font-family:'DM Sans',sans-serif;">Adresse *</span>
            <input type="text" name="livraisonAdresse" maxlength="150" placeholder="12 rue de la Paix, Appt 3"
                   style="width:100%;background:var(--dark);border:1px solid var(--borderl);border-radius:2px;padding:.75rem 1rem;color:var(--cream);font-size:.875rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;"
                   onfocus="this.style.borderColor='rgba(201,169,110,0.5)'" onblur="this.style.borderColor='var(--borderl)'"/>
            <span class="error-msg hidden mt-1 text-xs text-red-400" data-error-for="livraisonAdresse"></span>
          </label>
          <div class="grid sm:grid-cols-2 gap-4">
            <label class="block">
              <span style="display:block;font-size:.8rem;color:var(--cream);margin-bottom:.5rem;font-family:'DM Sans',sans-serif;">Code postal *</span>
              <input type="text" name="livraisonCodePostal" maxlength="10" placeholder="01170"
                     style="width:100%;background:var(--dark);border:1px solid var(--borderl);border-radius:2px;padding:.75rem 1rem;color:var(--cream);font-size:.875rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;"
                     onfocus="this.style.borderColor='rgba(201,169,110,0.5)'" onblur="this.style.borderColor='var(--borderl)'"/>
              <span class="error-msg hidden mt-1 text-xs text-red-400" data-error-for="livraisonCodePostal"></span>
            </label>
            <label class="block">
              <span style="display:block;font-size:.8rem;color:var(--cream);margin-bottom:.5rem;font-family:'DM Sans',sans-serif;">Ville *</span>
              <input type="text" name="livraisonVille" maxlength="80" placeholder="Gex"
                     style="width:100%;background:var(--dark);border:1px solid var(--borderl);border-radius:2px;padding:.75rem 1rem;color:var(--cream);font-size:.875rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;"
                     onfocus="this.style.borderColor='rgba(201,169,110,0.5)'" onblur="this.style.borderColor='var(--borderl)'"/>
              <span class="error-msg hidden mt-1 text-xs text-red-400" data-error-for="livraisonVille"></span>
            </label>
          </div>
        </div>
      </div>

      {# ─── CGV ─── #}
      <label class="flex items-start gap-3">
        <input type="checkbox" name="cgv" required
               style="margin-top:2px;width:16px;height:16px;border-radius:2px;border:1px solid var(--borderl);background:var(--dark);accent-color:var(--gold);flex-shrink:0;"/>
        <span style="font-size:.75rem;color:var(--muted);font-family:'DM Sans',sans-serif;line-height:1.6;">
          Je certifie être majeur (18 ans+) et j'accepte les
          <a href="/cgv/" style="color:var(--gold);text-decoration:underline;text-underline-offset:3px;">conditions générales de vente</a>
          ainsi que la
          <a href="/mentions-legales/" style="color:var(--gold);text-decoration:underline;text-underline-offset:3px;">politique de confidentialité</a>.
        </span>
      </label>
      <span class="error-msg hidden mt-1 text-xs text-red-400" data-error-for="cgv"></span>
    </div>

    {# Colonne droite : récap + CTAs #}
    <aside class="lg:sticky lg:top-24 self-start space-y-6">

      <div style="border-radius:2px;background:var(--dark2);border:1px solid var(--borderl);padding:1.5rem;">
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.25rem;letter-spacing:.12em;color:var(--cream);margin-bottom:1.25rem;font-weight:400;">RÉCAPITULATIF</h2>
        <div id="checkout-items" style="margin-bottom:1.25rem;max-height:18rem;overflow-y:auto;padding-right:.25rem;" class="space-y-3 text-sm"></div>
        <dl class="space-y-3 text-sm" style="border-top:1px solid var(--borderl);padding-top:1rem;">
          <div class="flex justify-between">
            <dt style="color:var(--muted);font-family:'DM Sans',sans-serif;">Sous-total HT</dt>
            <dd style="font-family:'Space Mono',monospace;color:var(--cream);font-size:.8rem;" id="checkout-total-ht">0,00 €</dd>
          </div>
          <div class="flex justify-between">
            <dt style="color:var(--muted);font-family:'DM Sans',sans-serif;">TVA (20 %)</dt>
            <dd style="font-family:'Space Mono',monospace;color:var(--cream);font-size:.8rem;" id="checkout-total-tva">0,00 €</dd>
          </div>
          <div class="flex justify-between hidden" id="frais-port-row">
            <dt style="color:var(--muted);font-family:'DM Sans',sans-serif;">Frais de port</dt>
            <dd style="font-family:'Space Mono',monospace;color:var(--cream);font-size:.8rem;" id="frais-port-value">3,90 €</dd>
          </div>
          <div class="flex justify-between pt-3" style="border-top:1px solid var(--borderl);">
            <dt style="font-family:'Cormorant Garamond',serif;font-size:1rem;letter-spacing:.1em;color:var(--cream);">TOTAL TTC</dt>
            <dd style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:var(--gold);" id="checkout-total-ttc">0,00 €</dd>
          </div>
        </dl>
      </div>

      {# Boutons de paiement #}
      <div class="space-y-3">
        <button type="submit" name="mode" value="en-magasin" data-mode="en-magasin" id="btn-en-magasin"
                class="btn-ghost w-full py-4 text-sm uppercase tracking-widest flex items-center justify-center gap-2.5">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          Réserver &amp; payer en boutique
        </button>
        <button type="submit" name="mode" value="viva-wallet" data-mode="viva-wallet"
                class="btn-gold w-full py-4 text-sm uppercase tracking-widest flex items-center justify-center gap-2.5 font-bold">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>
          Payer en ligne (CB)
        </button>
        <p style="font-size:.7rem;color:var(--muted);text-align:center;font-family:'DM Sans',sans-serif;">
          Paiement sécurisé via <strong style="color:var(--cream);">Viva Wallet</strong> — CB, Apple Pay, Google Pay, Bancontact.
        </p>
      </div>

      <div id="checkout-status" class="hidden p-4 text-sm" style="border-radius:2px;"></div>
    </aside>
  </form>

  {# ── Script : bascule Click & Collect / Livraison ── #}
  <script>
  (function () {
    const btnCC      = document.getElementById('mode-cc-btn');
    const btnLiv     = document.getElementById('mode-livraison-btn');
    const hiddenMode = document.getElementById('mode-livraison-hidden');
    const sectionCC  = document.getElementById('section-cc');
    const sectionLiv = document.getElementById('section-livraison');
    const iconCC     = document.getElementById('icon-cc');
    const iconLiv    = document.getElementById('icon-livraison');

    function setMode(mode) {
      const isCC = mode === 'click-and-collect';
      hiddenMode.value = mode;

      // Click & Collect btn
      if (isCC) {
        btnCC.style.border = '1px solid var(--gold)';
        btnCC.style.background = 'rgba(201,169,110,0.06)';
        btnCC.classList.add('mode-active');
        iconCC.style.background = 'rgba(201,169,110,0.15)';
        iconCC.querySelector('svg').style.color = 'var(--gold)';
        btnCC.querySelector('span[style*="DM Sans"]').style.color = 'var(--gold)';
      } else {
        btnCC.style.border = '1px solid var(--borderl)';
        btnCC.style.background = 'transparent';
        btnCC.classList.remove('mode-active');
        iconCC.style.background = 'rgba(201,169,110,0.08)';
        iconCC.querySelector('svg').style.color = 'var(--muted)';
        btnCC.querySelector('span[style*="DM Sans"]').style.color = 'var(--cream)';
      }

      // Livraison btn
      if (!isCC) {
        btnLiv.style.border = '1px solid var(--gold)';
        btnLiv.style.background = 'rgba(201,169,110,0.06)';
        btnLiv.classList.add('mode-active');
        iconLiv.style.background = 'rgba(201,169,110,0.15)';
        iconLiv.querySelector('svg').style.color = 'var(--gold)';
        btnLiv.querySelector('span[style*="DM Sans"]').style.color = 'var(--gold)';
      } else {
        btnLiv.style.border = '1px solid var(--borderl)';
        btnLiv.style.background = 'transparent';
        btnLiv.classList.remove('mode-active');
        iconLiv.style.background = 'rgba(201,169,110,0.08)';
        iconLiv.querySelector('svg').style.color = 'var(--muted)';
        btnLiv.querySelector('span[style*="DM Sans"]').style.color = 'var(--cream)';
      }

      // Sections
      sectionCC.classList.toggle('hidden', !isCC);
      sectionLiv.classList.toggle('hidden', isCC);

      // Recalcul frais de port
      if (typeof window.checkoutUpdateShipping === 'function') window.checkoutUpdateShipping();
    }

    btnCC.addEventListener('click',  () => setMode('click-and-collect'));
    btnLiv.addEventListener('click', () => setMode('livraison'));

    // C&C par défaut
    setMode('click-and-collect');
  })();
  </script>

{# Données produits exposées au JS #}
<script id="produits-data" type="application/json">
{{ produits | dump | safe }}
</script>
</section>
