  {# ── Script : bascule Click & Collect / Livraison ── #}
  <script>
  (function () {
    const btnCC       = document.getElementById('mode-cc-btn');
    const btnLiv      = document.getElementById('mode-livraison-btn');
    const hiddenMode  = document.getElementById('mode-livraison-hidden');
    const sectionCC   = document.getElementById('section-cc');
    const sectionLiv  = document.getElementById('section-livraison');
    const btnMagasin  = document.getElementById('btn-en-magasin');

    function setMode(mode) {
      const isCC = mode === 'click-and-collect';
      hiddenMode.value = mode;

      // Onglets visuels
      btnCC.className  = 'mode-btn rounded-2xl border-2 p-4 text-left transition-all ' +
        (isCC ? 'border-neon-green bg-neon-green/10' : 'border-dark-border bg-dark-card hover:border-smoke');
      btnLiv.className = 'mode-btn rounded-2xl border-2 p-4 text-left transition-all ' +
        (!isCC ? 'border-neon-violet bg-neon-violet/10' : 'border-dark-border bg-dark-card hover:border-smoke');

      // Icônes couleur
      btnCC.querySelector('span.w-8').className  = 'w-8 h-8 rounded-lg flex items-center justify-center shrink-0 ' + (isCC ? 'bg-neon-green/20' : 'bg-dark-border/60');
      btnCC.querySelector('svg').className        = 'w-4 h-4 ' + (isCC ? 'text-neon-green' : 'text-smoke');
      btnLiv.querySelector('span.w-8').className  = 'w-8 h-8 rounded-lg flex items-center justify-center shrink-0 ' + (!isCC ? 'bg-neon-violet/20' : 'bg-dark-border/60');
      btnLiv.querySelector('svg').className        = 'w-4 h-4 ' + (!isCC ? 'text-neon-violet' : 'text-smoke');

      // Sections
      sectionCC.classList.toggle('hidden',  !isCC);
      sectionLiv.classList.toggle('hidden',  isCC);

      // Bouton "payer en boutique" : masqué en mode livraison (pas de retrait possible)
      if (btnMagasin) btnMagasin.closest('.space-y-3')?.querySelectorAll('button')[0]
        ?.classList.toggle('hidden', false); // toujours visible

      // Recalcul frais de port dans le récap
      if (typeof window.checkoutUpdateShipping === 'function') window.checkoutUpdateShipping();
    }

    btnCC.addEventListener('click',  () => setMode('click-and-collect'));
    btnLiv.addEventListener('click', () => setMode('livraison'));

    // Initialisation : Click & Collect par défaut
    setMode('click-and-collect');
  })();
  </script>

{# Données produits exposées au JS pour hydrater le récapitulatif #}
<script id="produits-data" type="application/json">
{{ produits | dump | safe }}
</script>
</section>
