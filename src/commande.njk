            </button>
            <span id="cal-title" style="color:var(--cream);font-family:'DM Sans',sans-serif;font-size:.875rem;font-weight:500;text-transform:capitalize;"></span>
            <button type="button" id="cal-next" aria-label="Mois suivant"
