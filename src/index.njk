{# ═══════════════════════════════════════════════════════════════════════
   TOP VENTES
   ═══════════════════════════════════════════════════════════════════════ #}
<section style="padding:80px 0 96px;background:var(--dark);">
  <div class="section-pad" style="max-width:1280px;margin:0 auto;padding:0 40px;">

    <div class="section-header-flex fade-up" style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:48px;">
      <div>
        <div class="section-tag" style="justify-content:flex-start;margin-bottom:16px;">Bestsellers</div>
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(34px,4vw,54px);font-weight:300;color:var(--cream);line-height:1.1;">
          Nos plus <em style="font-style:italic;color:var(--gold-light);">populaires</em>
        </h2>
      </div>
      <a href="/boutique/" class="btn-ghost" style="padding:11px 28px;font-size:9.5px;">
        Voir tout
        <svg style="width:12px;height:12px;margin-left:8px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
