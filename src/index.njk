---
layout: layouts/base.njk
title: MaisonCBDVape – L'art de savourer autrement
description: MaisonCBDVape – Boutique premium CBD, Vape, Puffs et Chicha à Gex (01170). Large sélection soigneusement sourcée. Retrait Click & Collect ou livraison 48h.
permalink: /index.html
---

{% from "components/product-card.njk" import productCard %}

{# ═══════════════════════════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════════════════════════ #}
<section class="hero-bg" style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;">

  {# Grain texture #}
  <div class="hero-grain"></div>

  {# Ligne verticale déco #}
  <div class="hero-deco-line" style="position:absolute;left:60px;top:50%;transform:translateY(-50%);width:1px;height:180px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);opacity:.2;" aria-hidden="true"></div>

  <div class="hero-inner" style="max-width:1280px;margin:0 auto;padding:80px 40px 80px 100px;position:relative;z-index:2;width:100%;">
    <div class="hero-content-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;">

      {# ─── Texte gauche ─────────────────────────────────────────── #}
      <div style="animation:fadeUp 1.1s ease forwards;opacity:0;animation-delay:.4s;">
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:28px;">
          <div style="width:36px;height:1px;background:var(--gold);opacity:.55;"></div>
          <span style="font-size:10px;letter-spacing:.4em;text-transform:uppercase;color:var(--gold);">{{ site.adresse.ville }} · {{ site.adresse.codePostal }}</span>
        </div>

        <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(52px,7.5vw,96px);font-weight:300;line-height:1.0;color:var(--cream);margin-bottom:28px;">
          L'art de<br/>
          <em style="font-style:italic;color:var(--gold-light);">savourer</em><br/>
          autrement.
        </h1>

        <p style="font-size:13.5px;letter-spacing:.03em;line-height:1.85;color:rgba(245,240,232,0.5);max-width:400px;margin-bottom:48px;">
          Une sélection premium de CBD, Vape, Puffs et Chicha soigneusement sourcée.<br/>
          <strong style="color:rgba(245,240,232,0.75);font-weight:400;">Retrait à Gex</strong> ou <strong style="color:rgba(245,240,232,0.75);font-weight:400;">livraison 48h</strong> partout en France.
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:14px;margin-bottom:60px;">
          <a href="#univers" class="btn-gold">
            <span>Explorer la boutique</span>
            <svg style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="/nouveautes/" class="btn-ghost">Nouveautés</a>
        </div>

        {# Stats #}
        <div style="display:flex;gap:36px;align-items:center;">
          <div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;color:var(--gold-light);">{{ collections.produitsActifs.length }}+</div>
            <div style="font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);">Références</div>
          </div>
          <div style="width:1px;height:40px;background:var(--borderl);"></div>
          <div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;color:var(--gold-light);">4.9★</div>
            <div style="font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);">Satisfaction</div>
          </div>
          <div style="width:1px;height:40px;background:var(--borderl);"></div>
          <div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;color:var(--gold-light);">48h</div>
            <div style="font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);">Livraison</div>
          </div>
        </div>
      </div>

      {# ─── Visuel droit (showcase catégories) ──────────────────── #}
      <div class="hidden lg:block" style="position:relative;padding:2rem 1rem 1rem 2rem;">
        {% set cbdProduct  = (collections.bestsellers | where("categorie","cbd")   | first) or (collections.cbd   | first) %}
        {% set puffProduct = (collections.bestsellers | where("categorie","puffs") | first) or (collections.puffs | first) %}

        {# Floating card haut-gauche — ARCHIVÉE (peut être réactivée)
        {% if cbdProduct %}
          <div style="position:absolute;top:0;left:0;z-index:20;width:180px;background:var(--dark2);border:1px solid var(--borderl);overflow:hidden;animation:fadeUp 1.2s ease forwards;opacity:0;animation-delay:.9s;">
            {% if cbdProduct.image %}
              <div style="aspect-ratio:1/1;overflow:hidden;">
                <img src="{{ cbdProduct.image }}" alt="{{ cbdProduct.nom }}" style="width:100%;height:100%;object-fit:cover;" loading="eager"/>
              </div>
            {% endif %}
            <div style="padding:12px 14px;">
              <div style="font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;">CBD</div>
              <div style="font-size:13px;font-weight:400;color:var(--cream);line-height:1.3;">{{ cbdProduct.nom | truncate(22) }}</div>
              <div style="font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--gold);margin-top:4px;">{{ cbdProduct.prix | eur }}</div>
            </div>
          </div>
        {% endif %}
        #}

        {# Showcase central #}
        {% set vapecat = categories | where("slug","vape") | first %}
        <div style="position:relative;z-index:10;border:1px solid var(--borderl);overflow:hidden;aspect-ratio:4/5;">
          {% if vapecat and vapecat.image %}
            <img src="{{ vapecat.image }}" alt="Collection Vape" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="eager"/>
          {% endif %}
          <div style="position:absolute;inset:0;background:linear-gradient(180deg, rgba(14,12,9,0.3) 0%, rgba(14,12,9,0.7) 60%, rgba(14,12,9,0.95) 100%);"></div>
          <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:36px;text-align:center;">
            <div style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;color:var(--cream);letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px;">Collection<br/>Vape 2026</div>
            <div style="font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:20px;">Kits, Pods & E-liquides</div>
            <a href="/nouveautes/" style="display:inline-block;padding:8px 24px;border:1px solid rgba(201,169,110,0.35);font-size:9px;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);text-decoration:none;transition:border-color .25s,background .25s;"
               onmouseover="this.style.borderColor='var(--gold)';this.style.background='rgba(201,169,110,0.08)'"
               onmouseout="this.style.borderColor='rgba(201,169,110,0.35)';this.style.background='transparent'">Nouveautés disponibles</a>
          </div>
          <div style="position:absolute;top:16px;right:16px;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:rgba(245,240,232,0.3);">{{ site.adresse.ville | upper }} · {{ site.adresse.codePostal }}</div>
        </div>

        {# Floating card bas-droit — ARCHIVÉE (peut être réactivée)
        {% if puffProduct %}
          <div style="position:absolute;bottom:0;right:0;z-index:20;width:180px;background:var(--dark2);border:1px solid var(--borderl);overflow:hidden;animation:fadeUp 1.2s ease forwards;opacity:0;animation-delay:1.1s;">
            {% if puffProduct.image %}
              <div style="aspect-ratio:1/1;overflow:hidden;">
                <img src="{{ puffProduct.image }}" alt="{{ puffProduct.nom }}" style="width:100%;height:100%;object-fit:cover;" loading="eager"/>
              </div>
            {% endif %}
            <div style="padding:12px 14px;">
              <div style="font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;">Puffs</div>
              <div style="font-size:13px;font-weight:400;color:var(--cream);line-height:1.3;">{{ puffProduct.nom | truncate(22) }}</div>
              <div style="font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--gold);margin-top:4px;">{{ puffProduct.prix | eur }}</div>
            </div>
          </div>
        {% endif %}
        #}
      </div>

    </div>
  </div>

  {# Fade bottom #}
  <div style="position:absolute;bottom:0;left:0;right:0;height:120px;background:linear-gradient(0deg,var(--dark),transparent);pointer-events:none;"></div>

  {# Scroll indicator #}
  <div class="hero-scroll-hint" style="position:absolute;bottom:40px;left:60px;display:flex;align-items:center;gap:12px;font-size:9.5px;letter-spacing:.28em;text-transform:uppercase;color:rgba(245,240,232,0.28);animation:fadeUp 1s ease forwards;opacity:0;animation-delay:1.4s;">
    <div style="width:1px;height:44px;background:linear-gradient(to bottom,var(--gold),transparent);animation:pulse-gold 2.2s ease-in-out infinite;"></div>
    Défiler
  </div>
</section>


{# ═══════════════════════════════════════════════════════════════════════
   MARQUEE
   ═══════════════════════════════════════════════════════════════════════ #}
<div class="marquee-wrap" aria-hidden="true">
  <div class="marquee-track">
    {% set items = ["CBD Premium","Vape & E-liquides","Puffs","Chicha","Accessoires","Click & Collect","Livraison 48h","Gex · 01170"] %}
    {% for i in range(0,3) %}
      {% for item in items %}
        <span class="marquee-item"><span class="mdot"></span>{{ item }}</span>
      {% endfor %}
    {% endfor %}
  </div>
</div>


{# ═══════════════════════════════════════════════════════════════════════
   NOS UNIVERS — grille catégories
   ═══════════════════════════════════════════════════════════════════════ #}
<section id="univers" style="padding:96px 0 0;background:var(--dark);">
  <div class="section-pad" style="max-width:1280px;margin:0 auto;padding:0 40px;">

    <div style="text-align:center;margin-bottom:56px;" class="fade-up">
      <div class="section-tag" style="margin-bottom:18px;">Nos univers</div>
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(34px,4vw,54px);font-weight:300;color:var(--cream);line-height:1.1;">
        Une sélection <em style="font-style:italic;color:var(--gold-light);">soigneusement</em> choisie
      </h2>
    </div>

    {# Grille : 1ère carte grande (col 1-2), les 4 autres en 2×2 #}
    <div class="grid-cat-home" style="display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:360px 280px;gap:2px;">
      {% set catEmojis = {"cbd":"🌿","puffs":"💨","vape":"🔋","chicha":"🪔","accessoires":"🔥"} %}

      {% for cat in categories %}
        <a href="/categories/{{ cat.slug }}/" class="cat-card" style="{% if loop.first %}grid-row:1/3;height:100%;{% endif %}display:block;text-decoration:none;">
          <div class="cat-card-inner">
            {% if cat.image %}
              <img src="{{ cat.image }}" alt="{{ cat.nom }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.55;" loading="lazy"/>
            {% else %}
              {# Fallback gradient #}
              <div style="position:absolute;inset:0;background:linear-gradient(155deg,var(--dark2),var(--dark3));"></div>
            {% endif %}
          </div>
          <div class="cat-overlay"></div>
          <div class="cat-border-inset"></div>
          <div class="cat-content">
            <div style="font-size:9.5px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);opacity:.7;margin-bottom:6px;">{{ catEmojis[cat.slug] or "✦" }} Catégorie</div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:300;color:var(--cream);margin-bottom:10px;{% if loop.first %}font-size:2.4rem;{% else %}font-size:1.6rem;{% endif %}line-height:1.1;">{{ cat.nom }}</h3>
            <div class="cat-discover">
              <span>Découvrir</span>
              <svg style="width:12px;height:12px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>


