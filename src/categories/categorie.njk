---
layout: layouts/base.njk
pagination:
  data: categories
  size: 1
  alias: cat
permalink: "/categories/{{ cat.slug }}/index.html"
eleventyComputed:
  title: "{{ cat.nom }}"
  description: "{{ cat.description }}"
---
{# ──────────────────────────────────────────────────────────────────────────
   categorie.njk — UNE page par catégorie (5 au total)
   Source visuelle : docs/maquettes-source/02-categorie-vape.html
   ────────────────────────────────────────────────────────────────────────── #}

{% from "components/product-card.njk" import productCard %}

{# ── Préparation des données ─────────────────────────────────────────────── #}
{% set produitsCat   = produits | where("categorie", cat.slug) %}
{% set marquesCat    = produitsCat | pluck("marque") | unique %}
{% set prixMin       = produitsCat | pluck("prix") | min %}
{% set prixMax       = produitsCat | pluck("prix") | max %}
{% set nbProduits    = produitsCat | count %}
{% set nbMarques     = marquesCat | count %}

{# Couleur d'accent contextuelle #}
{% set accent = "#39FF14" %}
{% if cat.slug == "vape" or cat.slug == "puffs" %}{% set accent = "#BF5FFF" %}
{% elif cat.slug == "chicha" %}{% set accent = "#00D4FF" %}
{% elif cat.slug == "accessoires" %}{% set accent = "#8A8A9A" %}
{% endif %}

{# ═══════════════════════════════════════════════════════════════════════════
   HERO CATÉGORIE — fil d'Ariane + titre + stats
   ═══════════════════════════════════════════════════════════════════════════ #}
<div class="grid-lines relative">
  <div class="absolute left-1/4 top-12 w-80 h-80 rounded-full blur-3xl pointer-events-none"
       style="background:radial-gradient(circle,{{ accent }}1A 0%,transparent 70%);"></div>
  <div class="absolute right-1/4 top-8 w-64 h-64 rounded-full blur-3xl pointer-events-none"
       style="background:radial-gradient(circle,rgba(0,212,255,.08) 0%,transparent 70%);"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14 relative">

    <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 mb-6 text-xs font-mono fade-up">
      <a href="/" class="breadcrumb-link">Accueil</a>
      <svg class="w-3 h-3 text-dark-border" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
      <span style="color:{{ accent }};">{{ cat.nom }}</span>
    </nav>

    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 fade-up" style="transition-delay:.05s;">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full"
             style="border:1px solid {{ accent }}33;background:{{ accent }}0D;">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:{{ accent }};"></span>
          <span class="font-mono text-xs tracking-widest uppercase" style="color:{{ accent }};">Catégorie</span>
        </div>

        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl text-white tracking-wide mb-4 leading-none">
          {{ cat.nom | upper }}
        </h1>

        {% if cat.description %}
          <p class="text-smoke text-sm sm:text-base leading-relaxed">{{ cat.description }}</p>
        {% endif %}
      </div>

      {% if nbProduits > 0 %}
        <div class="flex gap-6 shrink-0">
          <div class="text-center">
            <div class="font-display text-3xl" style="color:{{ accent }};">{{ nbProduits }}</div>
            <div class="text-smoke text-xs tracking-wider uppercase font-mono">Produit{% if nbProduits > 1 %}s{% endif %}</div>
          </div>
          <div class="w-px bg-dark-border"></div>
          <div class="text-center">
            <div class="font-display text-3xl" style="color:#39FF14;">{{ nbMarques }}</div>
            <div class="text-smoke text-xs tracking-wider uppercase font-mono">Marque{% if nbMarques > 1 %}s{% endif %}</div>
          </div>
          <div class="w-px bg-dark-border"></div>
          <div class="text-center">
            <div class="font-display text-3xl" style="color:#00D4FF;">48h</div>
            <div class="text-smoke text-xs tracking-wider uppercase font-mono">Livraison</div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="neon-divider"></div>
</div>


{# ═══════════════════════════════════════════════════════════════════════════
   CONTENU PRINCIPAL — sidebar + grille produits
   ═══════════════════════════════════════════════════════════════════════════ #}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">

  {# Bouton mobile pour ouvrir le drawer filtres #}
  <div class="flex items-center justify-between mb-6 lg:hidden">
    <p class="text-smoke text-sm font-mono">{{ nbProduits }} résultat{% if nbProduits > 1 %}s{% endif %}</p>
    <button id="open-filters" type="button"
            class="flex items-center gap-2 px-4 py-2.5 rounded-xl border border-dark-border bg-dark-card text-sm text-white font-medium transition hover:border-neon-violet/40">
      <svg class="w-4 h-4" style="color:{{ accent }};" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM3.75 6h.75m16.5 6H6.75m0 0a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM3.75 12h.75m16.5 6H13.5m0 0a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM3.75 18h.75"/>
      </svg>
      Filtrer &amp; Trier
    </button>
  </div>

  <div class="flex gap-8 relative">

    {# ─────────────────────── SIDEBAR (desktop) ─────────────────────── #}
    <aside class="hidden lg:block w-64 xl:w-72 shrink-0">
      <div class="space-y-5 sticky top-24 overflow-y-auto" style="max-height:calc(100vh - 7rem); scrollbar-width:thin; scrollbar-color:#1E1E2E transparent;">

        {# Sous-catégories (pour MVP : "Tout voir" + chaque autre univers) #}
        <div class="sidebar-card p-5">
          <h2 class="filter-section-title mb-4">Univers</h2>
          <div class="space-y-2">
            <a href="/categories/{{ cat.slug }}/" class="subcat-pill w-full active">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M12 17.25h7.5"/></svg>
              {{ cat.nomCourt or cat.nom }} ({{ nbProduits }})
            </a>
            {% for autre in categories %}
              {% if autre.slug != cat.slug %}
                <a href="/categories/{{ autre.slug }}/" class="subcat-pill w-full">
                  <span style="color:{{ autre.couleurHex or '#8A8A9A' }};">●</span>
                  {{ autre.nomCourt or autre.nom }}
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Marques #}
        {% if marquesCat | count > 0 %}
          <div class="sidebar-card p-5">
            <h2 class="filter-section-title mb-4">Marques</h2>
            <div class="space-y-3">
              {% for marque in marquesCat %}
                {% set countMarque = produitsCat | where("marque", marque) | count %}
                <label class="check-row">
                  <input type="checkbox" data-filter-brand="{{ marque }}" />
                  <label>{{ marque }} <span class="text-smoke text-xs">({{ countMarque }})</span></label>
                </label>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {# Prix - double slider #}
        {% if nbProduits > 0 %}
          <div class="sidebar-card p-5">
            <h2 class="filter-section-title mb-4">Prix</h2>
            <div class="flex justify-between text-xs font-mono mb-3">
              <span id="price-display-min" style="color:#39FF14;">{{ prixMin | eur }}</span>
              <span id="price-display-max" class="text-smoke">{{ prixMax | eur }}</span>
            </div>
            <div id="price-slider-wrap" class="price-range-wrap"
                 data-prix-min="{{ prixMin }}" data-prix-max="{{ prixMax }}">
              <div id="price-range-fill" class="price-range-fill"></div>
              <input type="range" id="price-min" class="price-range-input"
                     min="{{ prixMin }}" max="{{ prixMax }}" step="0.5" value="{{ prixMin }}">
              <input type="range" id="price-max" class="price-range-input"
                     min="{{ prixMin }}" max="{{ prixMax }}" step="0.5" value="{{ prixMax }}">
            </div>
          </div>
        {% endif %}

        <button type="button"
                class="w-full py-2.5 rounded-xl border border-dark-border text-smoke text-sm font-medium hover:text-white hover:border-white/20 transition-all">
          Réinitialiser les filtres
        </button>
      </div>
    </aside>


    {# ─────────────────────── COLONNE PRODUITS ─────────────────────── #}
    <div class="flex-1 min-w-0">

      {# Toolbar : count + tri #}
      <div class="toolbar-bar flex flex-col sm:flex-row sm:items-center justify-between gap-3 px-5 py-3.5 mb-7 fade-up">
        <p class="text-smoke text-xs font-mono">
          Affichage <span class="text-white font-bold">1–{{ nbProduits }}</span> sur <span class="text-white font-bold">{{ nbProduits }}</span> résultat{% if nbProduits > 1 %}s{% endif %}
        </p>
        <div class="flex items-center gap-3">
          <label class="text-smoke text-xs uppercase tracking-wider font-mono shrink-0" for="sort-select">Trier par :</label>
          <select id="sort-select" class="sort-select">
            <option value="nouveautes">Nouveautés</option>
            <option value="prix-asc">Prix croissant</option>
            <option value="prix-desc">Prix décroissant</option>
            <option value="note">Mieux notés</option>
          </select>
        </div>
      </div>

      {# Grille produits #}
      {% if nbProduits > 0 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
          {% for produit in produitsCat %}
            {{ productCard(produit, "fade-up") }}
          {% endfor %}
        </div>
      {% else %}
        <div class="text-center py-20 rounded-2xl border border-dashed border-dark-border bg-dark-card/40">
          <div class="text-5xl mb-4">📦</div>
          <h3 class="font-display text-2xl text-white mb-2">Aucun produit pour le moment</h3>
          <p class="text-smoke text-sm max-w-md mx-auto mb-6">
            Cette catégorie est en cours de constitution. Revenez bientôt ou explorez les autres univers de la boutique.
          </p>
          <a href="/" class="btn-outline-violet inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold uppercase tracking-widest">
            Retour à l'accueil
          </a>
        </div>
      {% endif %}

    </div>
  </div>
</section>


{# ═══════════════════════════════════════════════════════════════════════════
   DRAWER FILTRES MOBILE (replique le sidebar)
   ═══════════════════════════════════════════════════════════════════════════ #}
<div id="drawer-overlay" class="hidden-overlay fixed inset-0 z-40 lg:hidden" aria-hidden="true"></div>

<aside id="filter-drawer"
       class="hidden-drawer fixed top-0 left-0 bottom-0 w-[85%] max-w-sm z-50 lg:hidden bg-dark-bg border-r border-dark-border overflow-y-auto"
       aria-label="Filtres et tri">
  <div class="p-5">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display text-xl tracking-wide text-white">FILTRES</h2>
      <button id="close-filters" type="button" class="icon-btn p-1" aria-label="Fermer les filtres">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    {# Univers #}
    <div class="mb-6">
      <h3 class="filter-section-title mb-3">Univers</h3>
      <div class="space-y-2">
        <a href="/categories/{{ cat.slug }}/" class="subcat-pill w-full active">{{ cat.nomCourt or cat.nom }} ({{ nbProduits }})</a>
        {% for autre in categories %}
          {% if autre.slug != cat.slug %}
            <a href="/categories/{{ autre.slug }}/" class="subcat-pill w-full">{{ autre.nomCourt or autre.nom }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="neon-divider my-4"></div>

    {# Marques #}
    {% if marquesCat | count > 0 %}
      <div class="mb-6">
        <h3 class="filter-section-title mb-3">Marques</h3>
        <div class="space-y-3">
          {% for marque in marquesCat %}
            {% set countMarque = produitsCat | where("marque", marque) | count %}
            <label class="check-row">
              <input type="checkbox" />
              <label>{{ marque }} <span class="text-smoke text-xs">({{ countMarque }})</span></label>
            </label>
          {% endfor %}
        </div>
      </div>

      <div class="neon-divider my-4"></div>
    {% endif %}

    {# Prix #}
    {% if nbProduits > 0 %}
      <div class="mb-6">
        <h3 class="filter-section-title mb-3">Prix</h3>
        <div class="flex flex-wrap gap-2">
          <button type="button" class="price-pill">Moins de 20 €</button>
          <button type="button" class="price-pill">20 € – 50 €</button>
          <button type="button" class="price-pill">Plus de 50 €</button>
        </div>
      </div>
    {% endif %}

    <button id="apply-filters" type="button"
            class="btn-neon-green w-full py-3 rounded-xl font-semibold text-sm uppercase tracking-widest">
      Voir les {{ nbProduits }} résultat{% if nbProduits > 1 %}s{% endif %}
    </button>
    <button type="button"
            class="w-full py-2.5 mt-3 rounded-xl border border-dark-border text-smoke text-sm hover:text-white transition-colors">
      Réinitialiser
    </button>
  </div>
</aside>


{# ═══════════════════════════════════════════════════════════════════════════
   JSON-LD CollectionPage (SEO)
   ═══════════════════════════════════════════════════════════════════════════ #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "{{ cat.nom }} — {{ site.nom }}",
  "url": "{{ site.url }}/categories/{{ cat.slug }}/",
  "description": "{{ cat.description }}"
}
</script>
